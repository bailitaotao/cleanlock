    "home.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When enabled, the screen turns black and keyboard input is blocked\nso you can clean your screen and keyboard safely."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると画面が黒くなり、キーボード入力が無効になります。\n画面やキーボードを安全に掃除できます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "开启后屏幕将变黑并屏蔽键盘按键\n方便你清洁屏幕与键盘。"
          }
        }
      }
    },
    "home.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Screen Cleaning Mode"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "画面クリーニングモード"
          }
        },
        "zh-Hans" : {
