    "permission.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disable keys like ⌘, ⌃, fn and ⏻\nto prevent accidental input while cleaning."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘、⌃、fn、⏻ などのキーを無効化し、\nクリーニング中の誤入力を防ぐために権限を許可してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "授权后可禁用 “⌘、⌃、fn、⏻” 等按键\n防止清洁过程中误触。"
          }
        }
      }
    },
    "permission.title" : {
